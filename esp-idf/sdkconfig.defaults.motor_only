# Motor-only diagnostic build. Skips esp_matter::start() so no Matter task, no WiFi/BLE
# init, no chip[DL] ISRs — isolates whether choppiness comes from Matter cohabitation
# or from the motor code itself. esp-matter component stays compiled in (it's a hard
# REQUIRES of main) but none of its APIs are called.
#
# Usage:
#   idf.py fullclean
#   idf.py -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.esp32c6;sdkconfig.defaults.motor_only" build flash monitor

CONFIG_APP_MATTER_ENABLED=n
