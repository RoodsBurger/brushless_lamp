## Phase 14a defaults — target-agnostic bits. Target-specific overlay lives in
## sdkconfig.defaults.esp32c6 (loaded by idf.py after setting the target).

## Partition table (kept from esp-matter example so Phase 14d's factory-partition flow
## slots in cleanly without a resize).
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0xC000
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

## Arduino-as-component setup. We call initArduino() from app_main ourselves; no
## setup()/loop() auto-spawn.
CONFIG_AUTOSTART_ARDUINO=n
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_TIMER_TASK_STACK_SIZE=4096

## Logging: INFO, keep DEBUG compiled-in so `esp_log_level_set("motor", ESP_LOG_DEBUG)`
## works from the monitor.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

## BT is off in 14a — no Matter, no BLE. NimBLE comes on in 14c with esp-matter.
CONFIG_BT_ENABLED=n
