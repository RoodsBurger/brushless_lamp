## Phase 14c defaults — target-agnostic bits. C6 overlay in sdkconfig.defaults.esp32c6.

## Partition table (production factory-partition slot already carved out for 14d).
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0xC000
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

## Arduino-as-component — we own app_main and call initArduino() ourselves.
CONFIG_AUTOSTART_ARDUINO=n
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_TIMER_TASK_STACK_SIZE=4096

## Arduino-esp32 ships a Matter library that #includes esp_matter.h — when paired with
## esp-matter in the same build it double-includes chip and the link fails. Enable
## selective compilation and do NOT set CONFIG_ARDUINO_SELECTIVE_Matter; the Arduino
## core (Serial, pinMode, millis, delay, attachInterrupt, ledcAttach) is always built
## and is all SimpleFOC + our code needs.
CONFIG_ARDUINO_SELECTIVE_COMPILATION=y
## These have default=y under selective compilation, so we must explicitly disable.
## Matter is the blocker: arduino-esp32's Matter.h #includes <esp_matter.h> but the
## component manifest doesn't declare esp_matter as a requires, so the link fails.
## We use the esp-matter C++ API from our own matter_app.cpp instead.
CONFIG_ARDUINO_SELECTIVE_Matter=n
CONFIG_ARDUINO_SELECTIVE_OpenThread=n
CONFIG_ARDUINO_SELECTIVE_Insights=n
CONFIG_ARDUINO_SELECTIVE_Zigbee=n

## Logging — INFO runtime, DEBUG compiled in so we can enable per-tag from the monitor.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

## Matter / NimBLE (esp-matter requires NimBLE, not Bluedroid).
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=n
CONFIG_BT_NIMBLE_ENABLE_CONN_REATTEMPT=n

## Matter IP stack bits.
CONFIG_LWIP_IPV6_AUTOCONFIG=y
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y
CONFIG_LWIP_IPV6_NUM_ADDRESSES=6
CONFIG_MBEDTLS_HKDF_C=y

## One dynamic endpoint is enough for 14c (color_temperature_light).
CONFIG_ESP_MATTER_MAX_DYNAMIC_ENDPOINT_COUNT=2
CONFIG_ENABLE_CHIP_SHELL=y

## No WiFi AP / softAP.
CONFIG_ENABLE_WIFI_AP=n
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n

## OTA requestor prepped (14d will flip the switch).
CONFIG_ENABLE_OTA_REQUESTOR=y

## Matter cluster trim — keep the lighting clusters, drop the rest.
CONFIG_SUPPORT_ACCOUNT_LOGIN_CLUSTER=n
CONFIG_SUPPORT_ACTIVATED_CARBON_FILTER_MONITORING_CLUSTER=n
CONFIG_SUPPORT_AIR_QUALITY_CLUSTER=n
CONFIG_SUPPORT_APPLICATION_BASIC_CLUSTER=n
